# RocketCursor procurement MCP server — SMTP config
# Copy to .env for LOCAL testing. On Render, set these in the dashboard instead.

# Gmail: use an App Password (https://myaccount.google.com/apppasswords),
# NOT your normal password. Requires 2FA enabled on the Google account.
# Port 465 = implicit SSL (works on networks that block 587/STARTTLS).
# Use 587 only if 465 is unavailable.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=your_gmail_address@gmail.com
SMTP_PASSWORD=your_16_char_app_password
# Optional; defaults to SMTP_USERNAME
SMTP_FROM=your_gmail_address@gmail.com

# Safety allowlist (comma-separated). While testing, lock sends to your test inbox.
# Leave empty to allow ANY recipient (not recommended for a public deployment).
ALLOWED_RECIPIENTS=iansun258726@gmail.com
