# Copy to .env and fill in. .env is gitignored.

# --- Loop agent (Anthropic / ASI1 / TokenRouter / TTC) ---
ANTHROPIC_API_KEY=
# LLM_PROVIDER selects the loop's reasoning model: anthropic (Claude), asi1, or tokenrouter
LLM_PROVIDER=anthropic
ASI1_API_KEY=
TTC_API_KEY=

# --- TokenRouter (OpenAI-compatible gateway to 300+ models) ---
# Used only when LLM_PROVIDER=tokenrouter. Each call routes to the cheapest
# capable model for its task tier; override per-tier or pin all with LLM_MODEL.
TOKENROUTER_API_KEY=
# TOKENROUTER_MODEL_DESIGN=anthropic/claude-opus-4.8-fast
# TOKENROUTER_MODEL_SPEC=deepseek/deepseek-v4-pro
# TOKENROUTER_MODEL_JUDGE=deepseek/deepseek-v4-pro
# TOKENROUTER_MODEL=anthropic/claude-opus-4.8-fast   # cross-task fallback

# --- Memory layer (Voyage embeddings + Redis Stack) ---
VOYAGE_API_KEY=

# Required for memory.ingest_failures discover/extract (Stagehand + Browserbase)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
MODEL_API_KEY=


PROCUREMENT_ENABLED=true
PROCUREMENT_APPROVAL_REQUIRED=true
# When true, RFQs are sent automatically right after a successful procurement run
# (requires RFQ_DRY_RUN=false and MCP_SERVER_URL set).
PROCUREMENT_AUTO_SEND=false
# Set to 0 to bypass results/procurement_cache/candidates.json
PROCUREMENT_CACHE=1
# Speed tuning (lower = faster smoke runs, fewer candidates)
# PROCUREMENT_MAX_URLS=2
# PROCUREMENT_MAX_DRILLDOWN=1
# PROCUREMENT_SEARCH_RESULTS=4
# PROCUREMENT_MAX_SEEDS=1
# Set false to search suppliers one-at-a-time per material
# PROCUREMENT_PARALLEL_SUPPLIERS=true

# Interaction Co Poke — RFQ email send (https://poke.com/docs/api)
# V2 key from https://poke.com/kitchen (must match the Poke account in iMessage)
POKE_API_KEY=
POKE_API_URL=https://poke.com/api/v1/inbound/api-message
# All RFQ sends go here while testing (not to suppliers)
RFQ_TEST_EMAIL=
# false = live handoff to Poke with user_approved_external_action: true
RFQ_DRY_RUN=true
# Name of the Poke MCP integration that sends email (see tools/procurement/mcp)
POKE_MCP_CONNECTION=RocketCursor Procurement
# Set this to send RFQs automatically by calling the MCP server directly (no Poke,
# no manual paste). Use your deployed/tunneled MCP endpoint, ending in /mcp.
# e.g. https://your-tunnel.ngrok-free.dev/mcp
MCP_SERVER_URL=

# --- Supplier auth (Stagehand login step; secrets stay in .env, never in code) ---
MCMASTER_USERNAME=
MCMASTER_PASSWORD=
SWAGELOK_USERNAME=
SWAGELOK_PASSWORD=
# Reuse logged-in sessions across runs (create via: npm run create-context -- McMaster)
BROWSERBASE_CONTEXT_MCMASTER=
BROWSERBASE_CONTEXT_SWAGELOK=
# McMaster verified/stealth mode (browserSettings.verified) requires Browserbase Enterprise.
# Leave off unless your plan includes Verified mode.
MCMASTER_USE_VERIFIED_PROXY=false
# Pause for human 2FA/CAPTCHA via Poke live-view link instead of failing
SUPPLIER_LOGIN_INTERACTIVE=false
# Max ms to wait for human to complete 2FA in interactive mode (default 180000)
SUPPLIER_LOGIN_TIMEOUT_MS=180000
# Retries for flaky supplier login before blocking the supplier for the run (default 2)
SUPPLIER_LOGIN_RETRIES=2
# Submit portal quote forms after BOM approval (default off — fills but does not click final submit)
QUOTE_AUTO_SUBMIT=false
# Set true or pass --approved to portal-quote runner after engineering review
BOM_APPROVED=false

# Optional — omit to use local Redis Stack on localhost:6379
# Shared by loop session state and memory.Memory when set
# REDIS_URL=redis://default:password@host:port

# --- Arize AX tracing + eval (optional; from your Arize space settings) ---
ARIZE_SPACE_ID=
ARIZE_API_KEY=
ARIZE_PROJECT_NAME=rocketcursor-loop

# --- Sentry error monitoring (optional; from your Sentry project settings) ---
SENTRY_DSN=
SENTRY_ENV=hackathon

# --- Frontend (Vite reads this same repo-root .env) ---
# Only VITE_ variables are exposed to browser code.
VITE_SENTRY_DSN=
VITE_SENTRY_ENV=hackathon
VITE_DEEPGRAM_API_KEY=
VITE_ANTHROPIC_API_KEY=
